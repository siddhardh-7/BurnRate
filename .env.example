# ── SigNoz ───────────────────────────────────────────────────────────────────
# Your SigNoz Cloud API URL (for queries and MCP). Not the OTLP endpoint.
SIGNOZ_API_URL=https://api.us.signoz.cloud

# Ingestion key from SigNoz Cloud → Settings → Ingestion Settings
SIGNOZ_API_KEY=your-signoz-ingestion-key

# OTLP endpoint for sending traces and metrics (gRPC port 4317)
OTLP_ENDPOINT=https://ingest.us.signoz.cloud:4317

# ── Anthropic (for Cost Guard) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Claude model Cost Guard uses for investigation (default: sonnet, balanced cost/quality)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Demo App ──────────────────────────────────────────────────────────────────
# Model used by the researcher agent — cheap by default, misrouted to sonnet under chaos
# RESEARCHER_MODEL=claude-haiku-4-5-20251001

# ── Cost Guard → Demo App control ────────────────────────────────────────────
# URL Cost Guard uses to throttle/restore agents after diagnosing an incident.
# In Docker: http://demo-app:8000 (set in docker-compose.yml automatically)
# Locally: http://localhost:8000
DEMO_APP_URL=http://localhost:8000

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack incoming webhook URL for incident reports (optional but great for demo)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: secure the /alert webhook endpoint with a shared secret
# WEBHOOK_SECRET=some-random-secret

# ── Optional overrides ────────────────────────────────────────────────────────
# Path to signoz-mcp-server binary (default: looks in PATH)
# SIGNOZ_MCP_BINARY=/usr/local/bin/signoz-mcp-server

# Path to a JSON file with custom model pricing (overrides bundled defaults)
# BURNRATE_PRICING_FILE=/path/to/my-pricing.json
