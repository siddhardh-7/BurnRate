# ── SigNoz ───────────────────────────────────────────────────────────────────
SIGNOZ_API_URL=https://ingest.us.signoz.cloud:443
SIGNOZ_API_KEY=your-signoz-ingestion-key

# OTLP endpoint (same as above for SigNoz Cloud, or http://localhost:4317 for self-hosted)
OTLP_ENDPOINT=https://ingest.us.signoz.cloud:4317

# ── Anthropic (for Cost Guard) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model Cost Guard uses
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Demo App ──────────────────────────────────────────────────────────────────
# Model used by the researcher agent (default: haiku = cheap)
# RESEARCHER_MODEL=claude-haiku-4-5-20251001

# ── Cost Guard ────────────────────────────────────────────────────────────────
# Slack incoming webhook URL for incident reports
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: secure the webhook endpoint
# WEBHOOK_SECRET=some-random-secret

# ── Optional: custom pricing override ────────────────────────────────────────
# Path to a JSON file with custom model pricing (overrides bundled defaults)
# BURNRATE_PRICING_FILE=/path/to/my-pricing.json
