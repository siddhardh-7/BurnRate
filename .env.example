# ── SigNoz ───────────────────────────────────────────────────────────────────
# Self-hosted SigNoz (foundryctl / docker-compose):
SIGNOZ_API_URL=http://localhost:8080
SIGNOZ_API_KEY=your-signoz-api-key

# SigNoz MCP server (built-in, enabled via casting.yaml — port 8000 by default)
SIGNOZ_MCP_URL=http://localhost:8000/mcp

# OTLP endpoint for traces, metrics + logs (gRPC port 4317)
# Used by both demo-app (all three signals) and Cost Guard (incident logs)
OTLP_ENDPOINT=http://localhost:4317

# SigNoz Cloud alternative (replace all three above):
# SIGNOZ_API_URL=https://api.us.signoz.cloud
# SIGNOZ_API_KEY=your-signoz-ingestion-key
# OTLP_ENDPOINT=https://ingest.us.signoz.cloud:4317
# SIGNOZ_MCP_URL=https://api.us.signoz.cloud/mcp

# ── Anthropic (for Cost Guard real LLM investigation) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Claude model Cost Guard uses (default: haiku for speed + cost)
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Cost Guard mock mode ───────────────────────────────────────────────────────
# true  = synthetic diagnosis, no Anthropic API calls (safe default for demos)
# false = real Claude investigation via SigNoz MCP (requires ANTHROPIC_API_KEY)
COST_GUARD_MOCK=true

# ── Demo App ──────────────────────────────────────────────────────────────────
# true = demo-app synthesizes LLM responses + token usage (no Anthropic credits
# needed; the cost pipeline, alert, and Cost Guard loop stay fully real)
# DEMO_FAKE_LLM=true

# URL Cost Guard uses to throttle/restore agents after diagnosing an incident.
# Docker Compose sets this automatically to http://demo-app:8001
# For local development: http://localhost:8001
DEMO_APP_URL=http://localhost:8001

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack incoming webhook URL for incident reports (optional but great for demo)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: secure the /alert webhook endpoint with a shared secret
# WEBHOOK_SECRET=some-random-secret

# ── SigNoz Notification Channel setup ────────────────────────────────────────
# When running SigNoz in Docker, configure the webhook URL as:
#   http://host.docker.internal:8082/alert
# NOT http://localhost:8082/alert — Docker containers can't reach host localhost.
# For EC2: http://<private-ip>:8082/alert

# ── Optional overrides ────────────────────────────────────────────────────────
# Path to a JSON file with custom model pricing (overrides bundled defaults)
# BURNRATE_PRICING_FILE=/path/to/my-pricing.json
