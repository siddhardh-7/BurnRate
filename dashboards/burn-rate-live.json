{
  "title": "Burnrate — Live Cost Monitor",
  "description": "Real-time LLM cost burn rate by service and agent. Your cost vital sign.",
  "tags": ["burnrate", "llm", "finops"],
  "layout": [
    {
      "id": "burn_rate_total",
      "title": "Total Burn Rate ($/min)",
      "description": "Sum of all LLM spend across all agents and services",
      "panelType": "graph",
      "query": {
        "queryType": "builder",
        "builderQueries": {
          "A": {
            "dataSource": "metrics",
            "aggregateOperator": "rate",
            "aggregateAttribute": { "key": "burnrate.cost.usd", "type": "Sum" },
            "timeAggregation": "rate",
            "spaceAggregation": "sum",
            "groupBy": []
          }
        }
      },
      "unit": "USD/min",
      "thresholds": [
        { "value": 1.0, "color": "yellow", "label": "Warning" },
        { "value": 5.0, "color": "red", "label": "Critical" }
      ]
    },
    {
      "id": "burn_rate_by_agent",
      "title": "Burn Rate by Agent ($/min)",
      "description": "Cost contribution per agent ID — spot the expensive one fast",
      "panelType": "graph",
      "query": {
        "queryType": "builder",
        "builderQueries": {
          "A": {
            "dataSource": "metrics",
            "aggregateOperator": "rate",
            "aggregateAttribute": { "key": "burnrate.cost.usd", "type": "Sum" },
            "groupBy": [{ "key": "burnrate.agent.id" }]
          }
        }
      },
      "unit": "USD/min"
    },
    {
      "id": "burn_rate_by_model",
      "title": "Cost by Model ($/min)",
      "description": "Which model is burning the most — reveals model misrouting",
      "panelType": "graph",
      "query": {
        "queryType": "builder",
        "builderQueries": {
          "A": {
            "dataSource": "metrics",
            "aggregateOperator": "rate",
            "aggregateAttribute": { "key": "burnrate.cost.usd", "type": "Sum" },
            "groupBy": [{ "key": "gen_ai.request.model" }]
          }
        }
      }
    },
    {
      "id": "hourly_projection",
      "title": "Projected Daily Cost ($)",
      "description": "Current burn rate × 24 hours",
      "panelType": "value",
      "query": {
        "queryType": "builder",
        "builderQueries": {
          "A": {
            "dataSource": "metrics",
            "aggregateOperator": "rate",
            "aggregateAttribute": { "key": "burnrate.cost.usd", "type": "Sum" },
            "expression": "A * 60 * 24"
          }
        }
      },
      "unit": "USD/day"
    }
  ]
}
