{
  "title": "Burnrate — Cost by Agent & Task",
  "description": "Drill-down cost attribution: which agent, which task, which user is spending what.",
  "tags": ["burnrate", "llm", "finops"],
  "layout": [
    {
      "id": "cost_by_agent_table",
      "title": "Top Agents by Spend (last 1h)",
      "panelType": "table",
      "query": {
        "queryType": "builder",
        "builderQueries": {
          "A": {
            "dataSource": "metrics",
            "aggregateOperator": "sum",
            "aggregateAttribute": { "key": "burnrate.cost.usd", "type": "Sum" },
            "groupBy": [{ "key": "burnrate.agent.id" }, { "key": "gen_ai.request.model" }],
            "orderBy": [{ "columnName": "value", "order": "desc" }],
            "limit": 10
          }
        }
      },
      "unit": "USD"
    },
    {
      "id": "cost_per_task",
      "title": "Average Cost per Task",
      "panelType": "graph",
      "query": {
        "queryType": "builder",
        "builderQueries": {
          "A": {
            "dataSource": "metrics",
            "aggregateOperator": "avg",
            "aggregateAttribute": { "key": "burnrate.cost.per_operation.usd", "type": "Histogram" },
            "groupBy": [{ "key": "burnrate.agent.id" }]
          }
        }
      },
      "unit": "USD"
    },
    {
      "id": "cost_by_feature",
      "title": "Cost by Feature",
      "panelType": "pie",
      "query": {
        "queryType": "builder",
        "builderQueries": {
          "A": {
            "dataSource": "metrics",
            "aggregateOperator": "sum",
            "aggregateAttribute": { "key": "burnrate.cost.usd", "type": "Sum" },
            "groupBy": [{ "key": "burnrate.feature" }]
          }
        }
      }
    },
    {
      "id": "token_vs_cost",
      "title": "Token Efficiency (tokens per $)",
      "description": "Higher = more tokens for your dollar. Lower = expensive model or prompt bloat.",
      "panelType": "graph",
      "query": {
        "queryType": "builder",
        "builderQueries": {
          "tokens": {
            "dataSource": "metrics",
            "aggregateOperator": "sum",
            "aggregateAttribute": { "key": "burnrate.tokens.output", "type": "Sum" },
            "groupBy": [{ "key": "burnrate.agent.id" }]
          },
          "cost": {
            "dataSource": "metrics",
            "aggregateOperator": "sum",
            "aggregateAttribute": { "key": "burnrate.cost.usd", "type": "Sum" },
            "groupBy": [{ "key": "burnrate.agent.id" }]
          },
          "efficiency": {
            "expression": "tokens / cost"
          }
        }
      }
    }
  ]
}
